{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    // "rootDir": "./src",
    "types": ["node"],
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": false,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@exceptions/*": ["./src/common/exceptions/*"],
      "@config/*": ["./src/common/config/*"],
      "@constant/*": ["./src/common/constant/*"],
      "@decorators/*": ["./src/common/decorators/*"],
      "@dto/*": ["./src/common/dto/*"],
      "@errors/*": ["./src/common/errors/*"],
      "@filters/*": ["./src/common/filters/*"],
      "@guards/*": ["./src/common/guards/*"],
      "@interceptors/*": ["./src/common/interceptors/*"],
      "@middlewares/*": ["./src/common/middlewares/*"],
      "@pipes/*": ["./src/common/pipes/*"],
      "@swagger/*": ["./src/common/swagger/*"],
      "@application/*": ["./src/core/application/*"],
      "@domain/*": ["./src/core/domain/*"],
      "@infrastructure/*": ["./src/core/infrastructure/*"],
      "@presentation/*": ["./src/presentation/*"]
    }
  },
  // "include": ["src/**/*", "prisma.config.ts"],
  // "exclude": ["node_modules"]
}